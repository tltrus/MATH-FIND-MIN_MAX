<Window x:Class="_3D_Chart_WPF_v1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:SurfacePlot="clr-namespace:WPFSurfacePlot3D"
        xmlns:local="clr-namespace:_3D_Chart_WPF_v1"
        mc:Ignorable="d"
        Title="GA / Find max point of function" Height="834" Width="1126">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <WrapPanel Grid.Row="0" >
            <Button Content="Start timer" x:Name="btnStart" VerticalAlignment="Center" Margin="5" Width="100" Click="btnStart_Click"/>
            <Button Content="Step +" x:Name="btnUpdate" VerticalAlignment="Center" Margin="5" Width="100" Click="btnUpdate_Click" />
            <Label Content="Generation: " VerticalAlignment="Center" Margin="5" />
            <Label Content="0" x:Name="lbEpoch" VerticalAlignment="Center" Margin="5" />
        </WrapPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <SurfacePlot:SurfacePlotView Grid.Column="0" x:Name="mySurfacePlotView" HorizontalAlignment="Stretch" Height="700" VerticalAlignment="Top" Background="White" />
            <TextBox Grid.Column="1" Name="rtbConsole" Text="" Margin="0" Height="700" Width="350" Background="White" Foreground="#FF272424" VerticalAlignment="Top" TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>
